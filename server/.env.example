# Clé DashScope (Qwen Cloud / Alibaba Cloud)
DASHSCOPE_API_KEY=sk-...

# Optionnel : clé Alibaba Cloud dédiée (si fournie, active le provider 'alibaba')
ALIBABA_API_KEY=sk-...

# Timeout sandbox exécution code (ms)
SANDBOX_TIMEOUT_MS=5000
# Clé OpenRouter pour Fable 5 et modèles externes
OPENROUTER_API_KEY=sk-...
# Referrer pour les requêtes OpenRouter
OPENROUTER_REFERRER=https://github.com/mosaic2025/la-caverne-aux-40-voleurs
# Host Ollama (optionnel)
OLLAMA_HOST=http://localhost:11434
# Guards MoE (on/off)
MOE_INPUT_GUARD=on
MOE_OUTPUT_GUARD=on
MOE_BAZAAR=on
MOE_SIROCCO=on
MOE_TRAITOR=on
