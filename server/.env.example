# ============================================================
# Providers AUTORISÉS : Qwen Cloud / AI Studio (DashScope),
# Alibaba Cloud, Ollama Cloud. Aucun autre provider.
# ============================================================

# Qwen Cloud / AI Studio (DashScope) — provider par défaut, requis
DASHSCOPE_API_KEY=sk-...

# Alibaba Cloud (optionnel — active le provider 'alibaba')
# ALIBABA_API_KEY=sk-...

# Ollama Cloud (optionnel)
# OLLAMA_HOST=http://localhost:11434

# --- Configuration runtime ---
SANDBOX_TIMEOUT_MS=5000
MOE_INPUT_GUARD=on
MOE_OUTPUT_GUARD=on
MOE_BAZAAR=on
MOE_SIROCCO=on
MOE_TRAITOR=on
# DEMO_MODE=on  # mocks si DASHSCOPE absent
